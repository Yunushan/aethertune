# JSON object mapping a sync account ID to a long, randomly generated token.
# Do not reuse this example token or commit a populated .env file.
AETHERTUNE_SYNC_USERS={"primary":"replace-with-a-long-random-token"}
# A secret manager can store sha256:<64-hex-digest> instead of either raw token.
# Keep this operations token separate from every sync-account token.
AETHERTUNE_OPS_TOKEN=replace-with-a-separate-long-random-token

# Host port exposed by Docker Compose. The container listens on 8080.
AETHERTUNE_PORT=8080
# Keep the service on loopback and put TLS in a reverse proxy. Set an explicit
# public address only when a firewall and TLS proxy protect the host.
AETHERTUNE_BIND_ADDRESS=127.0.0.1
