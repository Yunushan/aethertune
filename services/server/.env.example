# Managed accounts are created after startup through the operations API. Static
# token maps remain supported; leave this as {} for managed-only deployments.
AETHERTUNE_SYNC_USERS={}
# Keep this operations token separate from every sync-account token. A secret
# manager can store sha256:<64-hex-digest> instead of the raw token.
AETHERTUNE_OPS_TOKEN=replace-with-a-separate-long-random-token

# Host port exposed by Docker Compose. The container listens on 8080.
AETHERTUNE_PORT=8080
# Keep the service on loopback and put TLS in a reverse proxy. Set an explicit
# public address only when a firewall and TLS proxy protect the host.
AETHERTUNE_BIND_ADDRESS=127.0.0.1
# Docker containers must listen on their internal wildcard interface for the
# loopback-published host port above to reach them.
AETHERTUNE_LISTEN_ADDRESS=0.0.0.0
