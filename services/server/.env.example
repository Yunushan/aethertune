# JSON object mapping a sync account ID to a long, randomly generated token.
# Do not reuse this example token or commit a populated .env file.
AETHERTUNE_SYNC_USERS={"primary":"replace-with-a-long-random-token"}
# A secret manager can store sha256:<64-hex-digest> instead of a raw token.

# Host port exposed by Docker Compose. The container listens on 8080.
AETHERTUNE_PORT=8080
