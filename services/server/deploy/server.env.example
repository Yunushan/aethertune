# Keep this file root-readable only after installation.
# The single quotes are consumed by systemd and preserve JSON double quotes.
AETHERTUNE_SYNC_USERS='{}'
AETHERTUNE_OPS_TOKEN=replace-with-a-separate-long-random-token
# Optional: expire managed device tokens after 1-3650 days. Static users remain non-expiring.
# AETHERTUNE_MANAGED_TOKEN_TTL_DAYS=365
PORT=8080
# Native deployments bind to loopback unless an explicit IP address is set.
AETHERTUNE_LISTEN_ADDRESS=127.0.0.1
